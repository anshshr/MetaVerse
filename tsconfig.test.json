{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "node",
    "verbatimModuleSyntax": false,
    "isolatedModules": false,
    "noUncheckedSideEffectImports": false,
    "esModuleInterop": true,
    "types": ["node", "jest"]
  },
  "include": ["tests/**/*", "src/**/*"]
}